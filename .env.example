# Weather Edge, configuration template.
#
# Copy this file to `.env` and fill in your own values:
#     cp .env.example .env
#
# `.env` is gitignored and MUST NEVER be committed. Every value below maps to a
# field on Settings in src/weather_edge/config.py (pydantic-settings reads the
# UPPER_CASE env var of the same name). Nothing here is required to run the test
# suite or the read-only `forecast` / `markets` commands.

# ─── Database (optional for paper/backtest) ──────────────────────────────────
# Default is local Postgres. Persistence is only needed for live scheduling and
# the dashboard; the analysis pipeline and tests run without a database.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/weather_edge

# Redis (optional, used for cross-process caching when running the scheduler)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ─── AI reasoning layer (recommended) ────────────────────────────────────────
# Without these the pipeline still runs but the Claude/Gemini review steps are
# skipped ("AI reasoning will be degraded").
# Claude (Meteorologist):  https://console.anthropic.com/  -> API Keys
ANTHROPIC_API_KEY=
# Gemini (Risk Quant):     https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ─── Weather data (optional) ─────────────────────────────────────────────────
# Open-Meteo works on the free tier with no key. A customer key removes the
# inter-city rate-limit delay and enables parallel model fetches ($30/mo tier).
OPENMETEO_API_KEY=
OPENMETEO_PAID_TIER=false
# GribStream (optional): adds GraphCast / AIFS AI models. https://gribstream.com
GRIBSTREAM_API_KEY=

# ─── Strategy / sizing (have sane defaults; override only if you know why) ────
BANKROLL=1000.0
MIN_EDGE=0.05
MIN_CONFIDENCE=0.6
KELLY_FRACTION=0.25
MAX_POSITION_PCT=0.03
FETCH_INTERVAL_MINUTES=30

# ─── Live execution on Polymarket (DANGER, see README status banner) ────────
# Only needed to place REAL trades, which is NOT recommended (this bot lost 75%
# of its capital). Leave blank for paper trading. POLYMARKET_PRIVATE_KEY is the
# ONLY true secret here, it controls real funds. Never paste it anywhere public,
# never commit it, and prefer a fresh wallet with limited funds for any testing.
POLYMARKET_PRIVATE_KEY=
POLYMARKET_WALLET=
# 2 = EOA wallet, 1 = Polymarket proxy / Magic Link
POLYMARKET_SIGNATURE_TYPE=2
# CLOB API credentials (create at https://polymarket.com/settings -> API)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
# Relayer API key for gasless proxy-wallet redemption
POLYMARKET_RELAYER_API_KEY=
