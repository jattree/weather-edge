# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/weather_edge

# Trading
BANKROLL=1000.0
MIN_EDGE=0.05
MIN_CONFIDENCE=0.6
KELLY_FRACTION=0.5
MAX_POSITION_PCT=0.05

# Scheduling
FETCH_INTERVAL_MINUTES=30

# Open-Meteo (set to true after subscribing to paid tier at $30/month)
# Paid tier removes inter-city delay and enables parallel model fetches
OPENMETEO_PAID_TIER=false

# Polymarket (Phase 3)
# POLYMARKET_API_KEY=
# WALLET_PRIVATE_KEY=
